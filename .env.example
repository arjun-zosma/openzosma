# ── Database ──────────────────────────────────────────────────────────────────
# Used by gateway (individual vars) and web app (connection string)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openzosma
DB_USER=openzosma
DB_PASS=openzosma
DB_POOL_SIZE=20
DATABASE_URL=postgresql://openzosma:openzosma@localhost:5432/openzosma

# ── Valkey / Redis (not yet implemented) ─────────────────────────────────────
VALKEY_URL=redis://localhost:6379

# ── RabbitMQ (not yet implemented) ───────────────────────────────────────────
RABBITMQ_URL=amqp://openzosma:openzosma@localhost:5672

# ── Web App (apps/web) ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# Auth (better-auth reads AUTH_SECRET for session signing)
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# AES-256 encryption key for integration credentials stored in DB.
# In dev, a fallback is used automatically. In production, set a 64-char hex
# string or a passphrase (will be derived via scrypt).
ENCRYPTION_KEY=

# Google OAuth (optional -- remove socialProviders block in auth.ts if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0
PUBLIC_URL=http://localhost:4000

# ── Agent ─────────────────────────────────────────────────────────────────────
# LLM provider for the pi-agent. Values: openai, anthropic, google, etc.
OPENZOSMA_MODEL_PROVIDER=anthropic
OPENZOSMA_MODEL_ID=claude-sonnet-4-20250514

# Workspace root for local-mode agent sessions
OPENZOSMA_WORKSPACE=./workspace

# Path to a directory served as initial knowledge base context
KNOWLEDGE_BASE_PATH=

# ── Sandbox / Orchestrator ────────────────────────────────────────────────────
# Controls how agent sessions are executed.
#   local       -- pi-agent runs in-process inside the gateway (default, no OpenShell needed)
#   orchestrator -- delegates to per-user OpenShell sandboxes via the orchestrator
OPENZOSMA_SANDBOX_MODE=local

# The following vars only matter when OPENZOSMA_SANDBOX_MODE=orchestrator.
# They override the defaults in packages/orchestrator/src/types.ts (DEFAULT_CONFIG).
SANDBOX_IMAGE=openzosma/sandbox-server:latest
SANDBOX_POLICY_PATH=infra/openshell/policies/default.yaml
SANDBOX_AGENT_PORT=8080
SANDBOX_READY_TIMEOUT_MS=300000
SANDBOX_IDLE_SUSPEND_MS=1800000
SANDBOX_HEALTH_CHECK_INTERVAL_MS=60000
MAX_SANDBOXES=0

# Port the sandbox-server listens on inside the sandbox container
SANDBOX_SERVER_PORT=8080

# ── LLM Provider Keys (at least one required) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
