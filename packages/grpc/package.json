		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.12.6",
		"@openzosma/logger": "workspace:*",
		"@protobuf-ts/runtime": "^2.9.6",
		"@protobuf-ts/runtime-rpc": "^2.9.6",
		"@protobuf-ts/grpc-transport": "^2.9.6"
	},
	"devDependencies": {
		"@protobuf-ts/plugin": "^2.9.6",
		"@types/node": "^22.15.2",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3"
	}
