{
	"name": "@openzosma/db",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit",
		"migrate": "tsx src/migrate.ts up",
		"migrate:down": "tsx src/migrate.ts down",
		"migrate:auth": "tsx src/migrate-auth.ts",
		"migrate:create": "db-migrate create --sql-file --migrations-dir migrations"
	},
	"dependencies": {
		"@openzosma/logger": "workspace:*",
		"db-migrate": "^0.11.14",
		"db-migrate-pg": "^1.5.2",
		"pg": "^8.13.3"
	},
	"devDependencies": {
		"@types/node": "^22.15.2",
		"@types/pg": "^8.11.11",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3"
	}
}
