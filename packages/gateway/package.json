{
	"name": "@openzosma/gateway",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./session-manager": {
			"types": "./dist/session-manager.d.ts",
			"import": "./dist/session-manager.js"
		},
		"./adapters": {
			"types": "./dist/adapters.d.ts",
			"import": "./dist/adapters.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit",
		"dev": "tsx watch --env-file=../../.env.local src/index.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.1",
		"@openzosma/a2a": "workspace:*",
		"@openzosma/agents": "workspace:*",
		"@openzosma/auth": "workspace:*",
		"@openzosma/db": "workspace:*",
		"@openzosma/grpc": "workspace:*",
		"@openzosma/logger": "workspace:*",
		"@openzosma/orchestrator": "workspace:*",
		"a2a-js": "^0.2.0",
		"dotenv": "17.3.1",
		"hono": "^4.7.6",
		"ws": "^8.18.1"
	},
	"devDependencies": {
		"@types/node": "^22.15.2",
		"@types/ws": "^8.18.1",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
