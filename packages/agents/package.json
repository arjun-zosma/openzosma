{
	"name": "@openzosma/agents",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		}
	},
	"scripts": {
		"build": "pnpm run compile && pnpm run copy-assets",
		"compile": "tsc",
		"copy-assets": "mkdir -p dist/pi/subagents && cp src/pi/subagents/*.md dist/pi/subagents/",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@aliou/pi-guardrails": "^0.9.5",
		"@mariozechner/pi-ai": "^0.61.0",
		"@mariozechner/pi-coding-agent": "^0.61.0",
		"@openzosma/logger": "workspace:*",
		"@openzosma/memory": "workspace:*",
		"@sinclair/typebox": "^0.34.48",
		"dotenv": "17.3.1",
		"pi-subagents": "^0.11.6",
		"pi-web-access": "^0.10.3",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.2",
		"typescript": "^5.7.3"
	}
}
