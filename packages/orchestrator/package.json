		"@openzosma/db": "workspace:*",
		"@openzosma/logger": "workspace:*",
		"@openzosma/sandbox": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.15.2",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3"
	}
}
